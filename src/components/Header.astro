---
interface NavLink {
	label: string;
	href: string;
}

interface Props {
	links: NavLink[];
}

const { links } = Astro.props;
---

<header class="fixed inset-x-0 top-0 z-50">
	<div
		class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10"
	>
		<a
			href="#"
			class="font-display text-lg font-semibold tracking-wide text-archive-warm-white transition-colors hover:text-archive-ivory md:text-xl"
		>
			DaveyPics Studio
		</a>

		<nav aria-label="Main navigation" class="hidden md:block">
			<ul class="flex items-center gap-8">
				{
					links.map((link) => (
						<li>
							<a
								href={link.href}
								class="text-sm font-medium tracking-wide text-archive-muted transition-colors hover:text-archive-warm-white"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<button
			type="button"
			id="menu-toggle"
			class="relative z-50 flex h-10 w-10 items-center justify-center rounded-sm border border-white/10 bg-black/30 text-archive-warm-white backdrop-blur-sm transition-colors hover:border-white/20 md:hidden"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label="Open menu"
		>
			<span class="sr-only">Menu</span>
			<span class="flex flex-col items-center justify-center gap-1.5" aria-hidden="true">
				<span class="menu-bar block h-px w-5 bg-current transition-all duration-300"></span>
				<span class="menu-bar block h-px w-5 bg-current transition-all duration-300"></span>
				<span class="menu-bar block h-px w-5 bg-current transition-all duration-300"></span>
			</span>
		</button>
	</div>

	<div
		id="mobile-menu"
		class="pointer-events-none invisible fixed inset-0 top-0 z-40 opacity-0 transition-opacity duration-300 md:hidden"
		aria-hidden="true"
	>
		<div
			id="mobile-menu-backdrop"
			class="absolute inset-0 bg-black/70 backdrop-blur-sm"
		></div>
		<nav
			aria-label="Mobile navigation"
			class="absolute inset-x-0 top-[73px] border-b border-white/5 bg-archive-charcoal/95 px-6 py-8 backdrop-blur-md"
		>
			<ul class="flex flex-col gap-1">
				{
					links.map((link) => (
						<li>
							<a
								href={link.href}
								class="mobile-nav-link block rounded-sm px-3 py-3 font-display text-2xl font-medium text-archive-warm-white transition-colors hover:bg-white/5 hover:text-archive-ivory"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>

	<div
		class="h-px bg-gradient-to-r from-transparent via-archive-border to-transparent"
		aria-hidden="true"
	></div>
</header>

<style>
	#menu-toggle[aria-expanded='true'] .menu-bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	#menu-toggle[aria-expanded='true'] .menu-bar:nth-child(2) {
		opacity: 0;
	}

	#menu-toggle[aria-expanded='true'] .menu-bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	#mobile-menu.is-open {
		pointer-events: auto;
		visibility: visible;
		opacity: 1;
	}
</style>

<script>
	function setupMobileMenu() {
		const toggle = document.getElementById('menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const backdrop = document.getElementById('mobile-menu-backdrop');
		const navLinks = menu?.querySelectorAll('.mobile-nav-link');

		if (!toggle || !menu) return;

		const closeMenu = () => {
			menu.classList.remove('is-open');
			menu.setAttribute('aria-hidden', 'true');
			toggle.setAttribute('aria-expanded', 'false');
			toggle.setAttribute('aria-label', 'Open menu');
			document.body.style.overflow = '';
		};

		const openMenu = () => {
			menu.classList.add('is-open');
			menu.setAttribute('aria-hidden', 'false');
			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Close menu');
			document.body.style.overflow = 'hidden';
		};

		toggle.addEventListener('click', () => {
			const isOpen = menu.classList.contains('is-open');
			if (isOpen) {
				closeMenu();
			} else {
				openMenu();
			}
		});

		backdrop?.addEventListener('click', closeMenu);

		navLinks?.forEach((link) => {
			link.addEventListener('click', closeMenu);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && menu.classList.contains('is-open')) {
				closeMenu();
			}
		});
	}

	setupMobileMenu();
	document.addEventListener('astro:page-load', setupMobileMenu);
</script>
